<?xml version="1.0"?>
<ruleset name="Scandiweb">
    <description>PSR-1, PSR-12, and PSR-4 compliance ruleset</description>

    <file>src</file>
    <file>public</file>
    <file>seeds</file>
    <file>migrations</file>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- PSR-1 and PSR-12 -->
    <rule ref="PSR1"/>
    <rule ref="PSR12"/>

    <!-- Enforce declare(strict_types=1) in all files -->
    <rule ref="SlevomatCodingStandard.TypeHints.DeclareStrictTypes">
        <properties>
            <property name="spacesCountAroundEqualsSign" value="0"/>
        </properties>
    </rule>

    <!-- PSR-4: class name must match file name -->
    <rule ref="SlevomatCodingStandard.Files.TypeNameMatchesFileName">
        <properties>
            <property name="rootNamespaces" type="array">
                <element key="src" value="App"/>
            </property>
        </properties>
    </rule>
</ruleset>
